# Copy this file to ".env" to override defaults. All values are optional —
# docker compose works out of the box without a .env file.
# No secrets are required: everything runs locally.

# ---- Models (swap to scale up/down) ----
OLLAMA_CHAT_MODEL=qwen2.5:3b-instruct
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ---- Qdrant ----
QDRANT_COLLECTION=mittelstandgpt
